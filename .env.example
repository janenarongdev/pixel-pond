# Prisma / Supabase PostgreSQL connection strings.
# Not listed in 03-ARCHITECTURE.md's env var list, but required by Prisma:
# DATABASE_URL  -> Supabase connection pooler (port 6543), used at runtime.
# DIRECT_URL    -> Supabase direct connection (port 5432), used for migrations.
DATABASE_URL=""
DIRECT_URL=""

# Auth.js (NextAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# GitHub OAuth (Auth.js provider)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
