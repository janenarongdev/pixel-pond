// Prisma schema for Pixel Pond.
// Mirrors 02-DATABASE.md exactly. Do not modify without updating that document.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------
// Auth.js (NextAuth v5) models, managed by @auth/prisma-adapter.
// 02-DATABASE.md refers to this as "auth.users" — the externally-managed
// authentication schema referenced by profiles.user_id.
// -----------------------------------------------------------------------

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts Account[]
  sessions Session[]
  profile  Profile?

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------
// Custom application schema — see 02-DATABASE.md for column definitions,
// relationships and business constraints.
// -----------------------------------------------------------------------

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  role          String   @default("player")
  gold          Int      @default(100)
  equippedRodId String?  @map("equipped_rod_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  equippedRod  Rod?          @relation("EquippedRod", fields: [equippedRodId], references: [id])
  inventory    Inventory[]
  catches      Catch[]
  transactions Transaction[]
  playerRods   PlayerRod[]

  @@map("profiles")
}

model FishSpecies {
  id        String   @id @default(uuid())
  name      String   @unique
  rarity    String
  dropRate  Decimal  @map("drop_rate")
  sellPrice Int      @map("sell_price")
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  inventory    Inventory[]
  catches      Catch[]
  transactions Transaction[]

  @@map("fish_species")
}

model Inventory {
  id            String @id @default(uuid())
  profileId     String @map("profile_id")
  fishSpeciesId String @map("fish_species_id")
  quantity      Int    @default(0)

  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fishSpecies FishSpecies @relation(fields: [fishSpeciesId], references: [id], onDelete: Cascade)

  @@unique([profileId, fishSpeciesId])
  @@map("inventory")
}

model Catch {
  id            String   @id @default(uuid())
  profileId     String   @map("profile_id")
  fishSpeciesId String   @map("fish_species_id")
  caughtAt      DateTime @default(now()) @map("caught_at")

  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fishSpecies FishSpecies @relation(fields: [fishSpeciesId], references: [id], onDelete: Cascade)

  @@map("catches")
}

model Rod {
  id        String  @id @default(uuid())
  name      String  @unique
  price     Int
  luckBonus Int     @map("luck_bonus")
  imageUrl  String? @map("image_url")

  playerRods         PlayerRod[]
  equippedByProfiles Profile[]   @relation("EquippedRod")

  @@map("rods")
}

model PlayerRod {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  rodId       String   @map("rod_id")
  purchasedAt DateTime @default(now()) @map("purchased_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rod     Rod     @relation(fields: [rodId], references: [id], onDelete: Cascade)

  @@unique([profileId, rodId])
  @@map("player_rods")
}

model Transaction {
  id            String   @id @default(uuid())
  profileId     String   @map("profile_id")
  fishSpeciesId String   @map("fish_species_id")
  quantity      Int
  totalGold     Int      @map("total_gold")
  createdAt     DateTime @default(now()) @map("created_at")

  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fishSpecies FishSpecies @relation(fields: [fishSpeciesId], references: [id], onDelete: Cascade)

  @@map("transactions")
}
